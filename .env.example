# ============================================================
# FisioPerto — Variáveis de Ambiente (exemplo)
# Copiar para .env.local e preencher. NUNCA commitar .env.local
# ============================================================

# ---------- Site ----------
NEXT_PUBLIC_SITE_NAME="FisioPerto"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------- Supabase ----------
# (Project Settings > API no painel do Supabase)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
# ATENÇÃO: chave secreta. SÓ no servidor (Server Actions / Route Handlers). Nunca no cliente.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ---------- Resend (emails transacionais) ----------
RESEND_API_KEY="re_..."
# Remetente verificado no Resend (domínio precisa de DNS verificado)
RESEND_FROM_EMAIL="FisioPerto <ola@teu-dominio.pt>"
# Para onde vão notificações internas (ex.: novo pedido de verificação OFP)
ADMIN_NOTIFICATION_EMAIL="rui@teu-dominio.pt"
